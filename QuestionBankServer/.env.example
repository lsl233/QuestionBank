DATABASE_URL=postgresql://postgres:123456@127.0.0.1/questionbank
PORT=3000
FILES_DIR=./files
JWT_SECRET=replace-with-a-random-secret-in-production
APPLE_CLIENT_ID=name.lsl.QuestionBankApp
APPLE_IAP_ENV=sandbox
APPLE_ROOT_CA_DIR=./certs

# 本地开发跳过 Apple JWS 签名校验；生产环境必须配置 Apple 根证书并设为 false
APPLE_IAP_SKIP_VERIFY=false
ENABLE_TEST_AUTH=false

# 七牛云对象存储：私有 Bucket + 后端签发临时签名 URL
QINIU_ENABLED=false
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_PUBLIC_DOMAIN=https://cdn.example.com
QINIU_PRIVATE_URL_EXPIRES=3600
